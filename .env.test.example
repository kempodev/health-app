# Copy this file to .env.test and fill in the values

# Same as your .env.local
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Supabase service role key (found in Supabase Dashboard > Settings > API)
# Required for creating/deleting test users and seeding data
SUPABASE_SERVICE_ROLE_KEY=

# Test user credentials (this user will be created and deleted by the test suite)
E2E_TEST_USER_EMAIL=e2e-test@health-app.test
E2E_TEST_USER_PASSWORD=test-password-change-me
